{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "teacher", "student"] },
        "fullName": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "fullName", "active"]
    },
    "AppLink": {
      "title": "AppLink",
      "description": "A link to an educational application",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "clicks": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "url", "imageUrl", "category", "clicks"]
    },
    "Information": {
      "title": "Information",
      "description": "An informational post or announcement",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string" },
        "category": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "date", "category", "active"]
    },
    "AppSettings": {
      "title": "AppSettings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "logoUrl": { "type": "string" },
        "appName": { "type": "string" },
        "loginBackgroundUrl": { "type": "string" }
      },
      "required": ["appName"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/links/{linkId}": {
      "schema": { "$ref": "#/entities/AppLink" },
      "description": "Educational links"
    },
    "/information/{infoId}": {
      "schema": { "$ref": "#/entities/Information" },
      "description": "Information posts"
    },
    "/settings/{settingId}": {
      "schema": { "$ref": "#/entities/AppSettings" },
      "description": "Global settings"
    }
  }
}
